    codexEntryId:
    guidingPrincipalTrigger:
  - choiceLabel: B
    outcomeText: There's nothing left to spare, not even time. They said they'd manage. I hope they were right.
    mechanicalEffect: Disorder remains; risk of worsening (apply manually)
